# Proyecto Córdoba — Template de variables de entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env con valores reales

# ─── Desarrollo local ───────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-replace-with-a-long-random-string
DATABASE_URL=postgres://user:password@host:5432/dbname
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Producción (Railway + Neon) ────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<string-largo-aleatorio>
# DATABASE_URL=postgresql://<neon-user>:<password>@<neon-host>/<db>?sslmode=require
# DEBUG=False
# ALLOWED_HOSTS=*.railway.app,<tu-dominio>.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://<tu-dominio>.up.railway.app,https://proyecto-cordoba.vercel.app
# CELERY_TASK_ALWAYS_EAGER=True
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── OCR Veryfi (opcional; sin credenciales usa modo mock) ──────────────────
# VERYFI_CLIENT_ID=
# VERYFI_CLIENT_SECRET=
# VERYFI_USERNAME=
# VERYFI_API_KEY=
