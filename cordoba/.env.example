# Proyecto Córdoba — Template de variables de entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env con valores reales

# ─── Desarrollo local ───────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-replace-with-a-long-random-string
DATABASE_URL=postgres://user:password@host:5432/dbname
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Producción (Railway + Neon) ────────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<string-largo-aleatorio: python -c "import secrets; print(secrets.token_urlsafe(64))">
# DATABASE_URL=postgresql://<neon-user>:<password>@<neon-host>/<db>?sslmode=require
# ALLOWED_HOSTS=<tu-dominio>.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://<tu-dominio>.up.railway.app
# CONN_MAX_AGE=60
# SESSION_COOKIE_AGE=43200

# ─── Celery + Redis (OCR asíncrono; en prod SIEMPRE worker real) ────────────
# CELERY_TASK_ALWAYS_EAGER=False
# CELERY_BROKER_URL=redis://<host>:6379/0
# CELERY_RESULT_BACKEND=redis://<host>:6379/0

# ─── Email (notificaciones de aprobación/rechazo) ───────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=<sendgrid-api-key>
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=Proyecto Córdoba <notificaciones@tudominio.com>

# ─── Storage S3 (media en producción, opcional) ─────────────────────────────
# USE_S3=True
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ─── OCR Veryfi (opcional; sin credenciales usa modo mock) ──────────────────
# VERYFI_CLIENT_ID=
# VERYFI_CLIENT_SECRET=
# VERYFI_USERNAME=
# VERYFI_API_KEY=
